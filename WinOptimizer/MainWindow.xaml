<Window x:Class="WinOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:WinOptimizer"
        Title="WinOptimizer" Height="760" Width="1120"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ============ Title bar (window chrome) ============ -->
            <Border Grid.Row="0" Background="{DynamicResource CardBrush}" CornerRadius="11,11,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="14,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="WinOptimizer" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="TbVersion" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}" />
                        <Border Margin="10,0,0,0" CornerRadius="4" Padding="6,2"
                                Background="{DynamicResource SecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛡" FontSize="10" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{l:Tr admin}" FontSize="10" Margin="4,0,0,0"
                                           Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="↗  Releases" Click="OpenReleases" Style="{StaticResource SecondaryButton}"
                                FontSize="11" Padding="10,3" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <Button Content="—" Click="Minimize" Style="{DynamicResource ChromeButton}" />
                        <Button Content="▢" Click="MaxRestore" Style="{DynamicResource ChromeButton}" />
                        <Button Content="✕" Click="CloseWin" Style="{DynamicResource ChromeButtonClose}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ body: sidebar + content ============ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" CornerRadius="0,0,0,11">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- brand -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,16,8">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="⚙" Foreground="{DynamicResource PrimaryBrush}" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="WinOptimizer" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="v1.0.1" FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- nav -->
                        <StackPanel Grid.Row="1" Margin="8,8">
                            <RadioButton x:Name="NavDashboard" Style="{StaticResource NavItem}" Tag="dashboard"
                                         GroupName="nav" IsChecked="True" Checked="Nav_Checked" Content="{l:Tr nav_dashboard}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="otimizacoes"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_optimizations}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="tweaks"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_tweaks}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="presets"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_presets}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="apps"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_apps}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="limpeza"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_cleanup}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="servicos"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_services}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="debloat"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_debloat}" />
                            <RadioButton Style="{StaticResource NavItem}" Tag="creditos"
                                         GroupName="nav" Checked="Nav_Checked" Content="{l:Tr nav_credits}" />
                        </StackPanel>

                        <!-- detected version + language -->
                        <StackPanel Grid.Row="2" Margin="12">
                            <!-- language toggle -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="LangEn" Grid.Column="0" GroupName="lang" Style="{StaticResource TabItemButton}"
                                             HorizontalAlignment="Center" Tag="En" Checked="Lang_Checked" Content="EN" />
                                <RadioButton x:Name="LangPt" Grid.Column="1" GroupName="lang" Style="{StaticResource TabItemButton}"
                                             HorizontalAlignment="Center" Tag="Pt" Checked="Lang_Checked" Content="PT" />
                            </Grid>

                            <Border CornerRadius="8" Padding="12,9"
                                    Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <StackPanel HorizontalAlignment="Left">
                                        <TextBlock Text="{l:Tr detected_version}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}" />
                                        <TextBlock x:Name="TbTargetVersion" FontSize="13" FontWeight="Medium" Margin="0,1,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="auto" FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                               Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- content -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- section header -->
                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock x:Name="TbTitle" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="TbDesc" FontSize="13" Margin="0,2,0,0"
                                           Foreground="{DynamicResource MutedForegroundBrush}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- global search -->
                                <Border Width="220" Height="34" CornerRadius="8" Margin="0,0,10,0"
                                        Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <TextBlock Text="🔎" FontSize="12" Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MutedForegroundBrush}" IsHitTestVisible="False" />
                                        <TextBlock x:Name="SearchHint" Text="{l:Tr search_placeholder}" FontSize="12" Margin="30,0,0,0"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}" IsHitTestVisible="False" />
                                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Padding="30,0,10,0"
                                                 VerticalContentAlignment="Center" FontSize="12" Foreground="{DynamicResource ForegroundBrush}"
                                                 CaretBrush="{DynamicResource ForegroundBrush}" TextChanged="Search_Changed" />
                                    </Grid>
                                </Border>

                                <Button Content="{l:Tr create_restore_point}" Style="{StaticResource SecondaryButton}"
                                        VerticalAlignment="Center" FontSize="12" Click="RestorePoint" />
                            </StackPanel>

                            <!-- search results -->
                            <Popup x:Name="SearchPopup" PlacementTarget="{Binding ElementName=SearchBox}" Placement="Bottom"
                                   AllowsTransparency="True" StaysOpen="False" HorizontalOffset="-150" VerticalOffset="8">
                                <Border Width="430" MaxHeight="420" Background="{DynamicResource CardBrush}" CornerRadius="10"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6">
                                    <StackPanel>
                                        <TextBlock x:Name="SearchEmpty" Text="{l:Tr search_no_results}" Visibility="Collapsed"
                                                   FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}" Margin="10" />
                                        <ScrollViewer MaxHeight="404" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="SearchResults">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,8" Margin="0,1" CornerRadius="6" Background="Transparent">
                                                            <Grid>
                                                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" MaxWidth="320">
                                                                    <TextBlock Text="{Binding Titulo}" FontSize="12" FontWeight="Medium"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding CategoriaLabel}" FontSize="10"
                                                                               Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,1,0,0" />
                                                                </StackPanel>
                                                                <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right"
                                                                          VerticalAlignment="Center" IsChecked="{Binding Ativo, Mode=TwoWay}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>

                    <!-- view host -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <ContentControl x:Name="ContentHost" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>

    <Window.Resources>
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SecondaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeButtonClose" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DestructiveBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>
