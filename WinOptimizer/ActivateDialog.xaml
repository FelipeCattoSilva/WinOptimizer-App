<Window x:Class="WinOptimizer.ActivateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:WinOptimizer"
        Title="Activate" Height="Auto" Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent">

    <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryBrush}" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr activate_title}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{l:Tr activate_summary}" FontSize="13" TextWrapping="Wrap" MaxWidth="380"
                               Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- badges -->
            <WrapPanel Grid.Row="1" Margin="0,16,0,0">
                <Border CornerRadius="9" Padding="10,4" Margin="0,0,8,0"
                        Background="{DynamicResource WarningSoftBrush}">
                    <TextBlock Text="{l:Tr activate_admin_badge}" FontSize="12" Foreground="{DynamicResource WarningBrush}" />
                </Border>
                <Border CornerRadius="9" Padding="10,4"
                        Background="{DynamicResource SecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBlock Text="{l:Tr activate_visible_badge}" FontSize="12" Foreground="{DynamicResource ForegroundBrush}" />
                </Border>
            </WrapPanel>

            <!-- command -->
            <StackPanel Grid.Row="2" Margin="0,18,0,0">
                <TextBlock Text="{l:Tr activate_cmd_label}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Border CornerRadius="8" Padding="14,12" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBlock x:Name="CmdText" FontFamily="{DynamicResource MonoFont}" FontSize="13"
                               TextWrapping="Wrap" Foreground="{DynamicResource ForegroundBrush}" />
                </Border>
            </StackPanel>

            <!-- credits -->
            <StackPanel Grid.Row="3" Margin="0,18,0,0">
                <TextBlock Text="{l:Tr activate_credit_label}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock FontSize="13" TextWrapping="Wrap" Foreground="{DynamicResource MutedForegroundBrush}">
                    <Run Text="{l:Tr activate_credit_text}" />
                    <LineBreak />
                    <Hyperlink NavigateUri="https://massgrave.dev/" RequestNavigate="OpenCredit"
                               Foreground="{DynamicResource PrimaryBrush}">https://massgrave.dev/</Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- actions -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="{l:Tr pd_cancel}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Cancelar" />
                <Button Content="{l:Tr activate_continue}" Style="{StaticResource PrimaryButton}" Click="Confirmar" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
