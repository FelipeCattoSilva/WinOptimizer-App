<Application x:Class="WinOptimizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WinOptimizer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- global converters -->
            <local:RiscoLabelConverter x:Key="RiscoLabel" />
            <local:RiscoForegroundConverter x:Key="RiscoFg" />
            <local:RiscoBackgroundConverter x:Key="RiscoBg" />
            <local:BoolToVisConverter x:Key="BoolToVis" />
            <local:NullableOsToVisConverter x:Key="OsToVis" />
            <local:OsLabelConverter x:Key="OsLabel" />
            <local:ServiceStatusTextConverter x:Key="SvcText" />
            <local:ServiceStatusBrushConverter x:Key="SvcBrush" />
            <local:StartupTextConverter x:Key="StartupText" />
            <local:ImpactoTextConverter x:Key="ImpactoText" />
            <local:ImpactoBrushConverter x:Key="ImpactoBrush" />
            <local:MbConverter x:Key="Mb" />
            <local:IniciaisConverter x:Key="Iniciais" />
            <local:AppStatusTextConverter x:Key="AppStatusText" />
            <local:AppStatusBrushConverter x:Key="AppStatusBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
