<UserControl x:Class="WinOptimizer.Views.OtimizacoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:WinOptimizer">
    <StackPanel>
        <!-- horizontal tabs -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,16">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TabBar" Orientation="Horizontal" />
            </ScrollViewer>
        </Border>

        <!-- tweak list -->
        <ItemsControl x:Name="List">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <WrapPanel>
                                    <TextBlock Text="{Binding Titulo}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" />
                                    <!-- risk badge -->
                                    <Border CornerRadius="9" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center"
                                            Background="{Binding Risco, Converter={StaticResource RiscoBg}}">
                                        <TextBlock Text="{Binding Risco, Converter={StaticResource RiscoLabel}}" FontSize="11" FontWeight="Medium"
                                                   Foreground="{Binding Risco, Converter={StaticResource RiscoFg}}" />
                                    </Border>
                                    <!-- needs restart -->
                                    <Border CornerRadius="9" Padding="8,2" Margin="6,0,0,0" VerticalAlignment="Center"
                                            Background="{DynamicResource SecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Visibility="{Binding RequerReinicio, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{l:Tr needs_restart}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}" />
                                    </Border>
                                    <!-- target os -->
                                    <Border CornerRadius="9" Padding="8,2" Margin="6,0,0,0" VerticalAlignment="Center"
                                            Background="{DynamicResource SecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Visibility="{Binding AlvoOS, Converter={StaticResource OsToVis}}">
                                        <TextBlock Text="{Binding AlvoOS, Converter={StaticResource OsLabel}}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}" />
                                    </Border>
                                </WrapPanel>

                                <TextBlock Text="{Binding Descricao}" TextWrapping="Wrap" FontSize="13" LineHeight="19" Margin="0,5,0,0"
                                           Foreground="{DynamicResource MutedForegroundBrush}" />

                                <StackPanel Orientation="Horizontal" Margin="0,7,0,0"
                                            Visibility="{Binding Ativo, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="↺" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{l:Tr reversible_note}" FontSize="11" Margin="5,0,0,0"
                                               Foreground="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Top"
                                      IsChecked="{Binding Ativo, Mode=TwoWay}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border x:Name="EmptyState" Visibility="Collapsed" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="0,32">
            <TextBlock Text="{l:Tr opt_empty}" TextAlignment="Center"
                       FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" />
        </Border>
    </StackPanel>
</UserControl>
