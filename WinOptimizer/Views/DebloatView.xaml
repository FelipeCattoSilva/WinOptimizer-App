<UserControl x:Class="WinOptimizer.Views.DebloatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:WinOptimizer">
    <StackPanel>
        <!-- header with presets -->
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle" FontSize="13" FontWeight="Medium" />
                    <TextBlock Text="{l:Tr debloat_desc}"
                               FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="{l:Tr debloat_preset_safe}" Style="{StaticResource SecondaryButton}"
                            FontSize="12" Margin="0,0,8,0" Click="PresetSeguro" />
                    <Button x:Name="RemoverBtn" Style="{StaticResource PrimaryButton}" FontSize="12" Click="Remover" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- app grid -->
        <ItemsControl x:Name="List">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16" Margin="0,0,8,8">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Removido}" Value="True">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <CheckBox Style="{StaticResource SquareCheckBox}" IsEnabled="{Binding Habilitado}"
                                          IsChecked="{Binding Selecionado, Mode=TwoWay}" />
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Nome}" FontSize="13" FontWeight="Medium" />
                                        <TextBlock Text="{l:Tr debloat_removed}" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   Visibility="{Binding Removido, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Publisher}" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- safe -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Visibility="{Binding SeguroRemover, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="🛡" FontSize="10" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{l:Tr debloat_safe}" FontSize="11" Margin="3,0,0,0" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- protected -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Visibility="{Binding SeguroRemover, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <TextBlock Text="🔒" FontSize="10" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{l:Tr debloat_protected}" FontSize="11" Margin="3,0,0,0" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
