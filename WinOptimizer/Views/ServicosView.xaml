<UserControl x:Class="WinOptimizer.Views.ServicosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:WinOptimizer">
    <StackPanel>
        <!-- ===== startup ===== -->
        <TextBlock Text="{l:Tr svc_startup_title}" FontSize="13" FontWeight="SemiBold" />
        <TextBlock Text="{l:Tr svc_startup_desc}"
                   FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,12" />

        <ItemsControl x:Name="StartupList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource SecondaryBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="{Binding Nome, Converter={StaticResource Iniciais}}" FontSize="12"
                                               FontFamily="{DynamicResource MonoFont}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Nome}" FontSize="13" FontWeight="Medium" />
                                    <TextBlock Text="{Binding Publisher}" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <Run Text="{l:Tr svc_impact}" Foreground="{DynamicResource MutedForegroundBrush}" />
                                    <Run Text="{Binding Impacto, Converter={StaticResource ImpactoText}, Mode=OneWay}"
                                         Foreground="{Binding Impacto, Converter={StaticResource ImpactoBrush}}" FontWeight="Medium" />
                                </TextBlock>
                                <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Ativo, Mode=OneWay}" Click="ToggleStartup" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===== services ===== -->
        <TextBlock Text="{l:Tr svc_services_title}" FontSize="13" FontWeight="SemiBold" Margin="0,24,0,0" />
        <TextBlock Text="{l:Tr svc_services_desc}"
                   FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,12" />

        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
            <ItemsControl x:Name="ServiceList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBrush}" Padding="16"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Nome}" FontSize="13" FontWeight="Medium" FontFamily="{DynamicResource MonoFont}" />
                                        <!-- core -->
                                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding Core, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="🔒" FontSize="10" VerticalAlignment="Center" />
                                            <TextBlock Text="{l:Tr svc_core}" FontSize="11" Margin="3,0,0,0" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <!-- safe to disable -->
                                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding NaoCore, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="🛡" FontSize="10" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="{l:Tr svc_safe_disable}" FontSize="11" Margin="3,0,0,0" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Descricao}" FontSize="12" Margin="0,2,0,0"
                                               Foreground="{DynamicResource MutedForegroundBrush}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                             Fill="{Binding Status, Converter={StaticResource SvcBrush}}" />
                                    <TextBlock Text="{Binding Status, Converter={StaticResource SvcText}}" FontSize="12" Margin="6,0,12,0"
                                               VerticalAlignment="Center" Foreground="{Binding Status, Converter={StaticResource SvcBrush}}" />
                                    <Border CornerRadius="9" Padding="8,2" Margin="0,0,12,0" VerticalAlignment="Center"
                                            Background="{DynamicResource SecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <TextBlock Text="{Binding Startup, Converter={StaticResource StartupText}}" FontSize="11"
                                                   Foreground="{DynamicResource MutedForegroundBrush}" />
                                    </Border>
                                    <CheckBox Style="{StaticResource ToggleSwitch}" IsEnabled="{Binding NaoCore}"
                                              IsChecked="{Binding EmExecucao, Mode=OneWay}" Click="ToggleService" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </StackPanel>
</UserControl>
