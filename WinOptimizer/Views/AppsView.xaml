<UserControl x:Class="WinOptimizer.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:WinOptimizer">
    <StackPanel>
        <!-- header -->
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr apps_header}" FontSize="13" FontWeight="Medium" />
                    <TextBlock x:Name="SubText" FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,2,0,0"
                               Text="{l:Tr apps_sub}" />
                </StackPanel>
                <Button x:Name="InstallBtn" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Click="Install" Content="⬇  Instalar (0)" />
            </Grid>
        </Border>

        <!-- category sub-tabs -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,14">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TabBar" Orientation="Horizontal" />
            </ScrollViewer>
        </Border>

        <!-- filtered list (mainwindow owns the scroll) -->
        <ItemsControl x:Name="List">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="14,0" Margin="0,0,8,6" Height="56" VerticalAlignment="Top">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <CheckBox Style="{StaticResource SquareCheckBox}" IsChecked="{Binding Selecionado, Mode=TwoWay}" />
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Nome}" FontSize="13" FontWeight="Medium" />
                                    <TextBlock Text="{Binding WingetId}" FontSize="11" FontFamily="{DynamicResource MonoFont}"
                                               Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{Binding Status, Converter={StaticResource AppStatusText}}" FontSize="11"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{Binding Status, Converter={StaticResource AppStatusBrush}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Log -->
        <Border Style="{StaticResource Card}" Padding="12" Margin="0,8,0,0" MaxHeight="140">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" FontFamily="{DynamicResource MonoFont}" FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{l:Tr apps_log_ready}" />
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
