<UserControl x:Class="WinOptimizer.Views.LimpezaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:WinOptimizer">
    <StackPanel>
        <!-- done banner -->
        <Border x:Name="FreedBanner" Visibility="Collapsed" CornerRadius="10" Padding="16" Margin="0,0,0,12"
                Background="{DynamicResource SuccessSoftBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💾" FontSize="13" VerticalAlignment="Center" />
                <TextBlock x:Name="FreedText" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource SuccessBrush}" />
            </StackPanel>
        </Border>

        <!-- categories -->
        <ItemsControl x:Name="List">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <CheckBox Style="{StaticResource SquareCheckBox}" IsChecked="{Binding Selecionado, Mode=TwoWay}" />
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Nome}" FontSize="13" FontWeight="Medium" />
                                    <TextBlock Text="{Binding Descricao}" FontSize="12" FontFamily="{DynamicResource MonoFont}"
                                               Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{Binding TamanhoMb, Converter={StaticResource Mb}}" FontSize="13"
                                       FontFamily="{DynamicResource MonoFont}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedForegroundBrush}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- footer: total + action -->
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,4,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr cleanup_selected}" FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" />
                    <TextBlock x:Name="TotalText" FontSize="13" FontWeight="SemiBold" FontFamily="{DynamicResource MonoFont}" />
                </StackPanel>
                <Button x:Name="CleanBtn" Content="{l:Tr cleanup_now}" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" Click="Clean" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
