<UserControl x:Class="WinOptimizer.Views.PresetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:WinOptimizer">
    <UserControl.Resources>
        <!-- clickable preset card -->
        <Style x:Key="PresetCard" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{DynamicResource CardBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- applied banner -->
        <Border x:Name="AppliedBanner" Visibility="Collapsed" CornerRadius="10" Padding="16" Margin="0,0,0,12"
                Background="{DynamicResource SuccessSoftBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✓" FontSize="13" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                <TextBlock x:Name="AppliedText" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource SuccessBrush}" />
            </StackPanel>
        </Border>

        <TextBlock Text="{l:Tr presets_intro}"
                   FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

        <ItemsControl x:Name="List">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource PresetCard}" Click="OpenPreset" Tag="{Binding}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="9" Background="{DynamicResource SecondaryBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="{Binding Icone}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding Nome}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding Resumo}" FontSize="13" LineHeight="19" TextWrapping="Wrap" Margin="0,10,0,0"
                                       Foreground="{DynamicResource MutedForegroundBrush}" />
                            <TextBlock Text="{l:Tr presets_see_details}" FontSize="12" FontFamily="{DynamicResource MonoFont}" Margin="0,12,0,0"
                                       Foreground="{DynamicResource PrimaryBrush}" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
