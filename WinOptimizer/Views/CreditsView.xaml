<UserControl x:Class="WinOptimizer.Views.CreditsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:WinOptimizer">
    <StackPanel>
        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,0,0,16"
                   Foreground="{DynamicResource MutedForegroundBrush}"
                   Text="{l:Tr credits_intro}" />

        <ItemsControl x:Name="List">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Nome}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Autor}" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedForegroundBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Desc}" TextWrapping="Wrap" FontSize="13" LineHeight="19" Margin="0,6,0,0"
                                       Foreground="{DynamicResource MutedForegroundBrush}" />
                            <TextBlock FontSize="12" FontFamily="{DynamicResource MonoFont}" Margin="0,8,0,0">
                                <Hyperlink NavigateUri="{Binding Url}" RequestNavigate="OpenLink"
                                           Foreground="{DynamicResource PrimaryBrush}" TextDecorations="None">
                                    <Run Text="{Binding Url, Mode=OneWay}" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,8,0,0">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="WinOptimizer v1.0.3" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="{l:Tr credits_footer}"
                               FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <Button Content="{l:Tr credits_releases_btn}" Style="{StaticResource SecondaryButton}"
                        FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Click="OpenReleases" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
