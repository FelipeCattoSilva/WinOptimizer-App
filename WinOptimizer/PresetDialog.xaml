<Window x:Class="WinOptimizer.PresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:WinOptimizer"
        Title="Preset" Height="600" Width="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent">

    <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBlock x:Name="Icone" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="Nome" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="Resumo" FontSize="13" TextWrapping="Wrap" MaxWidth="400"
                               Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- badges: count + restart + risk -->
            <WrapPanel Grid.Row="1" Margin="0,16,0,0">
                <Border CornerRadius="9" Padding="10,4" Margin="0,0,8,0"
                        Background="{DynamicResource SecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBlock x:Name="CountText" FontSize="12" Foreground="{DynamicResource ForegroundBrush}" />
                </Border>
                <Border x:Name="RestartBadge" CornerRadius="9" Padding="10,4" Margin="0,0,8,0" Visibility="Collapsed"
                        Background="{DynamicResource WarningSoftBrush}">
                    <TextBlock Text="{l:Tr pd_restart_badge}" FontSize="12" Foreground="{DynamicResource WarningBrush}" />
                </Border>
                <Border x:Name="RiskBadge" CornerRadius="9" Padding="10,4">
                    <TextBlock x:Name="RiskText" FontSize="12" />
                </Border>
            </WrapPanel>

            <!-- content: improvements + affected tweaks -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="{l:Tr pd_improves}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl x:Name="MelhoriasList" Margin="0,0,0,18">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontSize="13" VerticalAlignment="Top" />
                                    <TextBlock Text="{Binding}" FontSize="13" TextWrapping="Wrap" MaxWidth="450" Margin="8,0,0,0"
                                               Foreground="{DynamicResource ForegroundBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="AfetadosTitle" Text="{l:Tr pd_will_enable}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl x:Name="AfetadosList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Padding="12,9" Margin="0,0,0,6">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" MaxWidth="380">
                                            <TextBlock Text="{Binding Titulo}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="⟳" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       Visibility="{Binding RequerReinicio, Converter={StaticResource BoolToVis}}" />
                                            <Border CornerRadius="9" Padding="8,2"
                                                    Background="{Binding Risco, Converter={StaticResource RiscoBg}}">
                                                <TextBlock Text="{Binding Risco, Converter={StaticResource RiscoLabel}}" FontSize="11" FontWeight="Medium"
                                                           Foreground="{Binding Risco, Converter={StaticResource RiscoFg}}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="EmptyAfetados" Visibility="Collapsed" FontSize="13"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{l:Tr pd_empty}" />
                </StackPanel>
            </ScrollViewer>

            <!-- actions -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="{l:Tr pd_cancel}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Cancelar" />
                <Button x:Name="ApplyBtn" Content="{l:Tr pd_apply}" Style="{StaticResource PrimaryButton}" Click="Aplicar" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
