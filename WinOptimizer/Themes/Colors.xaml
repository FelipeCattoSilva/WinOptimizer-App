<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- custom dark palette, hand-converted to hex -->
    <Color x:Key="BackgroundColor">#FF18191C</Color>
    <Color x:Key="SidebarColor">#FF1F2125</Color>
    <Color x:Key="CardColor">#FF25272B</Color>
    <Color x:Key="SecondaryColor">#FF303338</Color>
    <Color x:Key="AccentColor">#FF34373E</Color>
    <Color x:Key="ForegroundColor">#FFF2F3F5</Color>
    <Color x:Key="MutedForegroundColor">#FF9CA0A6</Color>
    <Color x:Key="PrimaryColor">#FF3E7BFA</Color>
    <Color x:Key="PrimaryForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="SuccessColor">#FF2FB271</Color>
    <Color x:Key="WarningColor">#FFE0A52A</Color>
    <Color x:Key="DestructiveColor">#FFE5484D</Color>
    <Color x:Key="BorderColor">#FF2E3036</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="{StaticResource MutedForegroundColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="{StaticResource PrimaryForegroundColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DestructiveBrush" Color="{StaticResource DestructiveColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />

    <!-- translucent tints for badge backgrounds -->
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#262FB271" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#26E0A52A" />
    <SolidColorBrush x:Key="DestructiveSoftBrush" Color="#26E5484D" />
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="#263E7BFA" />

    <CornerRadius x:Key="RadiusSm">5</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">10</CornerRadius>

    <FontFamily x:Key="MonoFont">Consolas, Cascadia Mono, monospace</FontFamily>

</ResourceDictionary>
